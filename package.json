{
  "name": "openclaw-deltachat",
  "version": "1.1.0",
  "description": "OpenClaw Delta Chat channel plugin",
  "main": "./dist/openclaw/channel.js",
  "exports": {
    ".": "./dist/lib/index.js",
    "./plugin": "./dist/openclaw/plugin.js",
    "./cli": "./dist/cli/index.js"
  },
  "files": [
